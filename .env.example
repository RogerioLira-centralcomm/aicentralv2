# Configurações do Banco de Dados PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aicentral_db
DB_USER=postgres
DB_PASSWORD=sua_senha_aqui

# Chave Secreta do Flask (gere uma aleatória para produção)
SECRET_KEY=sua_chave_secreta_aqui

# API Key do OpenRouter
OPENROUTER_API_KEY=sua_chave_openrouter_aqui

# URL base da aplicação (para URLs de imagens acessíveis externamente)
# Desenvolvimento:
BASE_URL=http://localhost:5000
# Produção (exemplo):
# BASE_URL=https://aicentral.centralcomm.media

# Ambiente
AICENTRAL_ENV=development

# WasenderAPI (WhatsApp CRM)
# Webhook URL (produção — domínio precisa existir no DNS):
# https://aicentral.centralcomm.media/crm/api/wasender/webhook
# Desenvolvimento local: use ngrok/cloudflare tunnel, ex.:
# https://SEU-TUNNEL.ngrok-free.app/crm/api/wasender/webhook
# Copie o webhook_secret da sessão Wasender para cá (header X-Webhook-Signature)
WASENDER_WEBHOOK_SECRET=
WASENDER_API_BASE_URL=https://www.wasenderapi.com/api
